{
  "ConnectionStrings": {
    "MongoDB": "mongodb://localhost:27017"
  },
  "OxQL": {
    "DatabaseName": "oxql_sample",
    "CollectionName": "documents",
    "MaxPageSize": 500,
    "DefaultPageSize": 50,
    "AllowedLookupSources": [ "customers", "products", "orders" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
